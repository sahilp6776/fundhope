# =============================================
# FundHope Frontend Environment Variables
# NEVER commit your actual .env to Git!
# =============================================

# Clerk Authentication (get from https://dashboard.clerk.com)
# 1. Go to Clerk Dashboard > Applications > Your App > API Keys
# 2. Copy the "Publishable Key" (starts with pk_test_ or pk_live_)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_Y2xhc3NpYy1zaGFyay0xNC5jbGVyay5hY2NvdW50cy5kZXYk

# Backend URL (local dev or deployed URL)
# MongoDB is configured on the backend and accessed through this API endpoint
VITE_BACKEND_URL=http://localhost:5000/api

# Razorpay Payment Gateway (get from https://dashboard.razorpay.com)
# 1. Go to Razorpay Dashboard > Settings > API Keys
# 2. Copy the "Key ID" (publishable key)
VITE_RAZORPAY_KEY_ID=rzp_test_SK2JywwbTX0hqk