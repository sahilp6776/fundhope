# =============================================
# FundHope Backend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit your actual .env to Git!
# =============================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS) 
# Development: http://localhost:3000
# Production: https://your-vercel-domain.vercel.app
FRONTEND_URL=http://localhost:3000

# MongoDB Connection String
# Development: mongodb://localhost:27017/fundhope
# Production: mongodb+srv://username:password@cluster.mongodb.net/fundhope
MONGODB_URI=mongodb://localhost:27017/fundhope

# Clerk Authentication (get from https://dashboard.clerk.com)
# Use test keys for development (sk_test_), production keys for production (sk_live_)
CLERK_SECRET_KEY=sk_test_F3cpbmX3Gf6eKyq3RZM97RWyJCZv9EgUDFm3Jz8OKX

# Razorpay Payment Gateway (get from https://dashboard.razorpay.com)
# Use test keys for development (rzp_test_), production keys for production (rzp_live_)
RAZORPAY_KEY_ID=rzp_test_SK2JywwbTX0hqk
RAZORPAY_KEY_SECRET=86JB5LV3vQvQWBjMahRJsaH2
